<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
  http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">
  <changeSet id="V10-audit-entry-client-id" author="satyam">
    <preConditions onFail="MARK_RAN">
      <not><columnExists tableName="audit_entry" columnName="client_id"/></not>
    </preConditions>
    <addColumn tableName="audit_entry">
      <column name="client_id" type="BIGINT"/>
    </addColumn>
    <createIndex tableName="audit_entry" indexName="idx_audit_entry_client_id">
      <column name="client_id"/>
    </createIndex>
  </changeSet>
</databaseChangeLog>
