<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
  http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">
  <changeSet id="V5-archive-tables" author="satyam">
    <preConditions onFail="MARK_RAN">
      <not><tableExists tableName="bureau_response_archive"/></not>
    </preConditions>
    <createTable tableName="bureau_response_archive">
      <column name="id" type="BIGINT"><constraints primaryKey="true"/></column>
      <column name="client_id" type="BIGINT"/>
      <column name="fico_score" type="INT"/>
      <column name="pulled_at" type="TIMESTAMP"/>
      <column name="archived_at" type="TIMESTAMP"/>
    </createTable>
    <createTable tableName="submission_record_archive">
      <column name="id" type="BIGINT"><constraints primaryKey="true"/></column>
      <column name="client_id" type="BIGINT"/>
      <column name="trigger_type" type="VARCHAR(50)"/>
      <column name="status" type="VARCHAR(50)"/>
      <column name="submitted_at" type="TIMESTAMP"/>
      <column name="archived_at" type="TIMESTAMP"/>
    </createTable>
  </changeSet>
</databaseChangeLog>
